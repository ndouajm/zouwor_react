RewriteEngine On

# API - rediriger vers le fichier PHP
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Servir les assets depuis dist/
RewriteRule ^assets/(.*)$ dist/assets/$1 [L]

# Servir les fichiers existants
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# SPA React
RewriteRule ^ /dist/index.html [L]